# OpenAI API Key
OPENAI_API_KEY="your-openai-api-key-here"

# MySQL/MariaDB connection (see DB-Design-Schema/)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=wholesale

# Optional: dedicated SELECT-only credentials for the chat assistant's
# NL2SQL queries (strongly recommended in production, ideally on a read
# replica). Falls back to DB_USER/DB_PASSWORD when unset — the session is
# still forced READ ONLY either way.
DB_RO_USER=
DB_RO_PASSWORD=
